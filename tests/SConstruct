#!/usr/bin/env python3
"""
SConstruct file for AIF Neural Network Framework Tests
Builds all available test executables
"""

import os

# Environment setup
env=Environment()

# Compiler settings
env.Append(CXXFLAGS=['-std=c++23', 
                     '-Wall', 
                     '-Wextra', 
                     '-O2',
                     '-fdiagnostics-color=always',
                    ])
env.Append(CPPPATH=[
    '../include',
    '../include/aif',
    '../../../include',
    '../../../third_party/include',
#    '../../../third_party/include/icu/common/',
#    '../../../third_party/include/icu/data/',
#    '../../../third_party/include/icu/i18n/',
#    '../../../third_party/include/icu/io/',
])
env.Append(LIBPATH=['../',
                    '../../../lib',
                    '../../../third_party/lib/release/linux/',
                   ])
env.Append(LIBS=['aif',
                 'ise',
                 'openblas',
                 'pthread',
                 'm',
                 'dl',
                 'gomp',
#                 'icuio',
#                 'icutu',
#                 'icui18n',
#                 'icuuc',
                ])
env.Append(CXXFLAGS=['-fopenmp'])

# CUDA toggle
cuda_enabled=int(ARGUMENTS.get('cuda',0))
if cuda_enabled==1:
  env.Append(CPPPATH=['../../../third_party/include/cuda'])
  env.Append(CPPPATH=['../../../third_party/include/cudnn'])
  env.Append(CXXFLAGS=['-DUSE_CAIF_CUDA'])
  env.Append(LIBPATH=['../../../third_party/lib/release/linux/cuda/'])
  env.Append(LIBS=['cublas_static',
                   'cublasLt_static',
                   'cudart_static',
                   'cudadevrt',
                   'cudnn',
                   'culibos',
                   'rt',
                   'dl',
                   'pthread'])

# Check if AIF library exists
aif_lib_path='../libcaif.a'
if not os.path.exists(aif_lib_path):
    print("Error: libcaif.a not found. Please build the AIF library first.")
    print("Run 'scons' in the parent directory.")
    Exit(1)

# Test source files
test_sources=[
    'test_activation_functions.cpp',
    'test_activations.cpp',
    'test_bias_gradients.cpp',
    'test_conv_layer.cpp', 
    'test_dense_layer.cpp',
    'test_dynamic_batch.cpp',
    'test_gradient_tensor_fix.cpp',
    'test_integration.cpp',
    'test_learning_process.cpp',
    'test_loss_functions.cpp',
    'test_matmul_ex.cpp',
    'test_network_serialization.cpp',
    'test_neural_network.cpp',
    'test_neural_network_training.cpp',
    'test_optimizers.cpp',
    'test_pythagorean_detailed.cpp',
    'test_pythagorean_example.cpp',
    'test_shapes.cpp',
    'test_tensor.cpp',
    'test_types.cpp',
    'test_reshape_layer.cpp',
    'test_evaluate.cpp',
    'test_gradients_api.cpp',
    'test_conv_backprop_activation_grad.cpp',
    'test_device_tensor.cpp',
    'test_device_rmsnorm.cpp',
    'test_device_layernorm.cpp',
    'test_device_attention.cpp',
    'test_device_ffn.cpp',
    'test_device_transformer_block.cpp',
    'test_device_rope.cpp',
    'test_device_gqa.cpp',
    'test_device_token_embedding.cpp',
    'test_device_patch_embedding.cpp',
    'test_device_positional_encoding.cpp',
    'test_device_linear_head.cpp',
    'test_device_transformer_model.cpp',
    'test_device_cross_entropy.cpp',
    'test_device_kv_cache.cpp',
    'test_device_multimodal_embedding.cpp',
    'test_transformer_training.cpp',
    'test_safetensors.cpp',
    'test_device_moe.cpp',
    'test_device_ml_attention.cpp',
    'test_device_pre_norm_block.cpp',
    'test_device_frozen_linear.cpp',
    'test_device_lora_adapter.cpp',
    'test_pluggable_projections.cpp',
    'test_flash_attn_backward_nan.cpp'
]

# Build individual test executables
test_executables=[]
for test_source in test_sources:
    if os.path.exists(test_source):
        # Extract test name (remove .cpp extension)
        test_name=os.path.splitext(test_source)[0]
        
        # Build the test executable
        test_exe=env.Program(target=test_name, source=test_source)
        test_executables.append(test_exe)
        print(f"Configured test: {test_name}")
    else:
        print(f"Warning: Test source file {test_source} not found, skipping...")

# Build test runner executable
if os.path.exists('run_all_tests.cpp'):
    run_all_tests_exe=env.Program( target='run_all_tests',source='run_all_tests.cpp')
    test_executables.append(run_all_tests_exe)
    print("Configured test runner: run_all_tests")

# Create aliases for running individual tests
for test_source in test_sources:
    if os.path.exists(test_source):
        test_name=os.path.splitext(test_source)[0]
        run_alias=f"run-{test_name.replace('_', '-')}"
        
        # Create alias that runs the test
        env.Alias(run_alias, test_name, f'./{test_name}')
        env.AlwaysBuild(run_alias)

# Create alias for running test runner
if os.path.exists('run_all_tests.cpp'):
    env.Alias('run-all-tests', 'run_all_tests', './run_all_tests')
    env.AlwaysBuild('run-all-tests')

# Create convenience aliases
env.Alias('tests', test_executables)
env.Alias('all', test_executables)

# Default target
Default(test_executables)

# Clean target
env.Clean('tests', test_executables)

# Help text
Help("""
AIF Neural Network Framework Test Build System

Targets:
  (default)           - Build all test executables
  tests              - Build all test executables  
  all                - Build all test executables
  run-all-tests      - Run the test runner program

Individual test targets:
""" + "\n".join([f"  {os.path.splitext(test)[0]:<30} - Build {test}" for test in test_sources if os.path.exists(test)]) + """

Run individual tests:
""" + "\n".join([f"  run-{os.path.splitext(test)[0].replace('_', '-'):<30} - Run {test}" for test in test_sources if os.path.exists(test)]) + """

Usage:
  scons                    - Build all tests
  scons tests              - Build all tests
  scons test_tensor        - Build specific test
  scons run-test-tensor    - Build and run specific test
  scons run-all-tests      - Build and run test runner
  scons -c                 - Clean all built files
""") 
